patch=1,EE,001A4998,word,0806B353
patch=1,EE,001A499C,word,A2020057

// ==== Hook B: matrix-builder prologue (aim-center) ======================
// NEW TARGET: j 0x001A49A0  (was j 0x001A5248)
patch=1,EE,01176AB4,word,08069268

// ==== Trampoline B body at 0x001A49A0 (MOVED, 12 words) =================
